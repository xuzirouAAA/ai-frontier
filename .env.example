# ============================================================
# 站点配置 - Vercel 部署必须设置
# ============================================================

# Google AdSense ID (生产环境设置)
# 格式: ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_ID=

# Google Analytics ID (生产环境设置)
# 格式: G-XXXXXXXXXX
# NEXT_PUBLIC_GA_ID=

# 站点 URL (生产环境设置)
# NEXT_PUBLIC_SITE_URL=https://ai-frontier.vercel.app

# ============================================================
# AI 自动写作 (仅本地使用，不在 Vercel 部署)
# ============================================================

# AI 提供商: agnes | anthropic
# AI_PROVIDER=agnes
# AGNES_API_KEY=sk-your-key-here
